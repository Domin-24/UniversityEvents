# ==================
# Database
# ==================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=university_events_db

# ==================
# Server
# ==================
PORT=5001
NODE_ENV=development

# ==================
# JWT Authentication
# ==================
# ใช้ random secret ที่ยาวและแข็งแกร่ง
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_strong_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d
